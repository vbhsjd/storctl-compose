#!/usr/bin/env bash
set -euo pipefail

cmd="${1:?missing command name}"
shift || true

root="${STORCTL_SIM_ROOT:?STORCTL_SIM_ROOT is required}"
log_dir="${root}/var/log/storctl-sim"
state_dir="${root}/var/lib/storctl-sim"
mkdir -p "${log_dir}" "${state_dir}"
log_file="${log_dir}/commands.log"
mounts_file="${state_dir}/mounts.tsv"
conns_file="${state_dir}/nm-connections.txt"

log_cmd() {
  {
    printf '%s' "${cmd}"
    for arg in "$@"; do
      printf ' %q' "${arg}"
    done
    printf '\n'
  } >> "${log_file}"
}

has_missing() {
  local needle="$1"
  local missing_csv="${STORCTL_SIM_MISSING_COMMANDS:-}"
  [[ -z "${missing_csv}" ]] && return 1
  IFS=',' read -r -a missing <<< "${STORCTL_SIM_MISSING_COMMANDS:-}"
  for item in "${missing[@]}"; do
    [[ "${item}" == "${needle}" ]] && return 0
  done
  return 1
}

iface_addr() {
  local dev="$1"
  local file="${root}/sys/class/net/${dev}/ipv4_addrs"
  [[ -f "${file}" ]] && sed -n '1p' "${file}"
}

set_mount() {
  local target="$1" fstype="$2" opts="$3" source="$4"
  touch "${mounts_file}"
  grep -v -F "${target}|" "${mounts_file}" > "${mounts_file}.tmp" || true
  mv "${mounts_file}.tmp" "${mounts_file}"
  printf '%s|%s|%s|%s\n' "${target}" "${fstype}" "${opts}" "${source}" >> "${mounts_file}"
}

remove_mount() {
  local target="$1"
  touch "${mounts_file}"
  grep -v -F "${target}|" "${mounts_file}" > "${mounts_file}.tmp" || true
  mv "${mounts_file}.tmp" "${mounts_file}"
}

mount_line() {
  local target="$1"
  [[ -f "${mounts_file}" ]] || return 1
  awk -F'|' -v target="${target}" '$1 == target {print; found=1} END {exit found ? 0 : 1}' "${mounts_file}"
}

log_cmd "$@"

if has_missing "${cmd}"; then
  echo "${cmd}: simulated missing command" >&2
  exit 127
fi

case "${cmd}" in
  storctl-sim-sh)
    printf '%s\n' "$*" >> "${log_dir}/shell.log"
    exit 0
    ;;

  nmcli)
    if [[ "${1:-}" == "-t" && "${2:-}" == "-f" && "${3:-}" == "NAME" && "${4:-}" == "con" && "${5:-}" == "show" ]]; then
      name="${6:-}"
      [[ -f "${conns_file}" ]] && grep -Fxq "${name}" "${conns_file}"
      exit $?
    fi
    if [[ "${1:-}" == "con" && "${2:-}" == "add" ]]; then
      name=""
      for ((i = 1; i <= $#; i++)); do
        if [[ "${!i}" == "con-name" ]]; then
          j=$((i + 1))
          name="${!j}"
        fi
      done
      [[ -n "${name}" ]] && { touch "${conns_file}"; grep -Fxq "${name}" "${conns_file}" || echo "${name}" >> "${conns_file}"; }
      exit 0
    fi
    if [[ "${1:-}" == "con" && "${2:-}" == "mod" ]]; then
      name="${3:-}"
      [[ -n "${name}" ]] && { touch "${conns_file}"; grep -Fxq "${name}" "${conns_file}" || echo "${name}" >> "${conns_file}"; }
      exit 0
    fi
    exit 0
    ;;

  ip)
    if [[ "${1:-}" == "-o" && "${2:-}" == "-4" && "${3:-}" == "addr" && "${4:-}" == "show" && "${5:-}" == "dev" ]]; then
      dev="${6:-}"
      addr="$(iface_addr "${dev}" || true)"
      [[ -n "${addr}" ]] && printf '2: %s    inet %s brd 0.0.0.0 scope global %s\n' "${dev}" "${addr}" "${dev}"
      exit 0
    fi
    if [[ "${1:-}" == "-s" && "${2:-}" == "link" && "${3:-}" == "show" ]]; then
      dev="${4:-}"
      state="UP"
      [[ -f "${root}/sys/class/net/${dev}/operstate" ]] && state="$(tr '[:lower:]' '[:upper:]' < "${root}/sys/class/net/${dev}/operstate")"
      printf '2: %s: <BROADCAST,MULTICAST,%s> mtu 5500 state %s mode DEFAULT group default qlen 1000\n' "${dev}" "${state}" "${state}"
      exit 0
    fi
    exit 0
    ;;

  rdma)
    [[ "${1:-}" == "link" && -f "${root}/sim/rdma_link" ]] && cat "${root}/sim/rdma_link"
    exit 0
    ;;

  hinicadm3)
    if [[ "${1:-}" == "info" ]]; then
      cat "${root}/sim/hinicadm3_info" 2>/dev/null || echo "hinic0(CAL_2X200G_INTERNET)"
    fi
    exit 0
    ;;

  ibdev2netdev)
    cat "${root}/sim/ibdev2netdev" 2>/dev/null || true
    exit 0
    ;;

  mlnx_qos|cma_roce_tos|modprobe|dracut|rpm|dnf)
    exit 0
    ;;

  tar)
    exit 0
    ;;

  systemctl)
    if [[ "${1:-}" == "start" && -f "${root}/sim/systemctl_start_fail" ]]; then
      echo "Job failed. See simulated journal." >&2
      exit 1
    fi
    exit 0
    ;;

  mount)
    opts=""
    source=""
    target=""
    while [[ $# -gt 0 ]]; do
      case "$1" in
        -o)
          opts="${2:-}"
          shift 2
          ;;
        -t)
          shift 2
          ;;
        *)
          source="${target}"
          target="$1"
          shift
          ;;
      esac
    done
    source="${source:-unknown}"
    if [[ "${opts}" == *"proto=rdma"* && -f "${root}/sim/rdma_mount_fail" ]]; then
      echo "mount.nfs: Protocol error" >&2
      exit 32
    fi
    if [[ "${opts}" == *"proto=tcp"* && -f "${root}/sim/tcp_mount_fail" ]]; then
      echo "mount.nfs: Connection timed out" >&2
      exit 32
    fi
    mkdir -p "${root}${target}"
    set_mount "${target}" "nfs4" "${opts}" "${source}"
    exit 0
    ;;

  umount)
    remove_mount "${1:-}"
    exit 0
    ;;

  findmnt)
    target=""
    for ((i = 1; i <= $#; i++)); do
      if [[ "${!i}" == "--mountpoint" ]]; then
        j=$((i + 1))
        target="${!j}"
      fi
    done
    line="$(mount_line "${target}" || true)"
    [[ -z "${line}" ]] && exit 1
    IFS='|' read -r _ fstype opts _ <<< "${line}"
    printf '%s    %s\n' "${fstype}" "${opts}"
    exit 0
    ;;

  nfsstat)
    [[ "${1:-}" == "-m" ]] || exit 0
    [[ -f "${mounts_file}" ]] || exit 0
    while IFS='|' read -r target _ opts source; do
      [[ -z "${target}" ]] && continue
      printf '%s from %s\n Flags:\t%s\n\n' "${target}" "${source}" "${opts}"
    done < "${mounts_file}"
    exit 0
    ;;

  *)
    exit 0
    ;;
esac
